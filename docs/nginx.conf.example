# ─── PGMRec — Nginx reverse proxy example (LAN) ──────────────────────────────
#
# Optional — use this if you want:
#   • A hostname instead of a raw IP (e.g. http://pgmrec.local)
#   • HTTPS with a self-signed or internal-CA certificate on your LAN
#   • Port 80/443 instead of :8000
#
# PGMRec is LAN-only; this configuration assumes an internal network.
# No public internet access or Let's Encrypt is required.
#
# Usage:
#   sudo cp docs/nginx.conf.example /etc/nginx/conf.d/pgmrec.conf
#   # Edit server_name to your LAN hostname or IP
#   sudo nginx -t && sudo systemctl reload nginx
#
# The backend must be started with --host 0.0.0.0 for Nginx to reach it.

# ─── HTTP-only (simplest LAN setup) ──────────────────────────────────────────
server {
    listen 80;
    server_name pgmrec.local 192.168.1.10;   # ← your LAN hostname or IP

    # Increase buffer for HLS segments (typically 200–400 kB per segment)
    proxy_buffering           on;
    proxy_buffer_size         16k;
    proxy_buffers             8 64k;
    proxy_busy_buffers_size   128k;

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Allow long-running HLS/streaming responses
        proxy_read_timeout  300s;
        proxy_send_timeout  300s;

        # Disable caching for live HLS playlists
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }
}

# ─── HTTPS with self-signed or internal-CA cert (optional) ───────────────────
# Uncomment if you want HTTPS on your LAN.
# Generate a self-signed cert:
#   openssl req -x509 -newkey rsa:4096 -days 3650 -nodes \
#     -keyout /etc/ssl/pgmrec/pgmrec.key \
#     -out    /etc/ssl/pgmrec/pgmrec.crt \
#     -subj "/CN=pgmrec.local"
#
# Or use a local CA (e.g. mkcert, Smallstep) for a browser-trusted LAN cert.
#
# server {
#     listen 443 ssl http2;
#     server_name pgmrec.local 192.168.1.10;
#
#     ssl_certificate     /etc/ssl/pgmrec/pgmrec.crt;
#     ssl_certificate_key /etc/ssl/pgmrec/pgmrec.key;
#     ssl_protocols       TLSv1.2 TLSv1.3;
#     ssl_ciphers         HIGH:!aNULL:!MD5;
#
#     proxy_buffering on;
#     proxy_buffer_size 16k;
#     proxy_buffers 8 64k;
#     proxy_busy_buffers_size 128k;
#
#     location / {
#         proxy_pass         http://127.0.0.1:8000;
#         proxy_http_version 1.1;
#         proxy_set_header   Host              $host;
#         proxy_set_header   X-Real-IP         $remote_addr;
#         proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
#         proxy_set_header   X-Forwarded-Proto $scheme;
#         proxy_read_timeout  300s;
#         proxy_send_timeout  300s;
#         add_header Cache-Control "no-cache, no-store, must-revalidate";
#     }
# }
#
# # Redirect HTTP to HTTPS
# server {
#     listen 80;
#     server_name pgmrec.local 192.168.1.10;
#     return 301 https://$host$request_uri;
# }
