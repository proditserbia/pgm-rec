# ─── PGMRec — Nginx reverse proxy example ────────────────────────────────────
#
# Place this file in /etc/nginx/conf.d/pgmrec.conf (or include it).
# Adjust server_name and certificate paths for your domain.
#
# This configuration:
#   - Redirects HTTP → HTTPS
#   - Proxies all requests to the PGMRec backend on port 8000
#   - Passes correct headers for WebSocket and HLS streaming
#   - Increases buffer sizes for HLS segment downloads

server {
    listen 80;
    server_name rec.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name rec.example.com;

    ssl_certificate     /etc/letsencrypt/live/rec.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/rec.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Increase buffer for HLS segments (typically 200–400 kB per segment)
    proxy_buffering           on;
    proxy_buffer_size         16k;
    proxy_buffers             8 64k;
    proxy_busy_buffers_size   128k;

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Allow long-running SSE / streaming responses
        proxy_read_timeout  300s;
        proxy_send_timeout  300s;
    }

    # Longer timeout for HLS m3u8 playlists and .ts segments
    location /api/v1/channels/ {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout  60s;

        # Disable caching for live HLS playlists
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }
}
