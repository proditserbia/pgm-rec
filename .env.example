# ─── PGMRec — Environment Configuration ──────────────────────────────────────
#
# ⚠️  SECURITY NOTICE — read before deploying
#
#   PGMRec is a LAN-only broadcast recording system.
#   It is NOT designed for public internet exposure.
#
#   Even on a LAN, the following MUST be done before first use:
#     1. Set a strong PGMREC_JWT_SECRET_KEY  (random 32+ byte hex string)
#     2. Set a strong PGMREC_ADMIN_PASSWORD  (not the default)
#     3. Set PGMREC_CORS_ORIGINS to your actual UI origin(s)
#     4. Do NOT open port 8000 to the internet without a firewall rule
#
#   The application runs fully offline on a LAN — no internet connectivity
#   is required at runtime.
#
# Copy this file to .env and edit to match your environment.
# The backend loads this file automatically via pydantic-settings.
# Naming convention:  PGMREC_<SETTING_NAME>
#
# ⚠️  Never commit .env to version control — it contains secrets.

# ─── Network binding ──────────────────────────────────────────────────────────
#
# Single-machine mode (default — only this machine can reach the service):
#   PGMREC_HOST=127.0.0.1
#
# LAN access mode (other machines on your LAN can reach the service):
#   PGMREC_HOST=0.0.0.0
#   Also set PGMREC_CORS_ORIGINS below to include your server's LAN IP.
#
PGMREC_HOST=127.0.0.1
PGMREC_PORT=8000

# ─── Authentication ───────────────────────────────────────────────────────────

# HS256 secret used to sign JWTs.  MUST be changed before first use.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
PGMREC_JWT_SECRET_KEY=change-me-before-starting-pgmrec-secret

# JWT expiry (minutes).  Default 480 = 8 hours.
# PGMREC_JWT_EXPIRE_MINUTES=480

# Initial admin account seeded on first startup.
# PGMREC_ADMIN_PASSWORD MUST be changed — the default is insecure.
PGMREC_ADMIN_USERNAME=admin
PGMREC_ADMIN_PASSWORD=pgmrec-admin

# ─── CORS (browser access control) ───────────────────────────────────────────
#
# Comma-separated list of browser origins allowed to call the API.
# Every entry must match scheme + host + port exactly.
#
# Default covers all local access patterns:
#   - Vite dev server:    http://localhost:5173  http://127.0.0.1:5173
#   - Embedded prod UI:   http://localhost:8000  http://127.0.0.1:8000
#
# Single-machine (default — covers both dev server and production UI):
PGMREC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# LAN access — add your server's LAN IP (replace 192.168.1.50 with your IP):
# PGMREC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.50:8000

# ─── Paths ────────────────────────────────────────────────────────────────────

# Root data directory.  All sub-directories (channels, manifests, exports,
# preview, recordings) are created under this path.
# Default: backend/data  (relative to the backend source directory)
# Linux systemd:   PGMREC_DATA_DIR=/opt/pgmrec/data
# Windows service: PGMREC_DATA_DIR=C:\PGMRec\data
# PGMREC_DATA_DIR=/opt/pgmrec/data

# Log files root directory.
# PGMREC_LOGS_DIR=/opt/pgmrec/logs

# Channel JSON config directory.
# PGMREC_CHANNELS_CONFIG_DIR=/opt/pgmrec/data/channels

# Manifest directory.
# PGMREC_MANIFESTS_DIR=/opt/pgmrec/data/manifests

# Export output directory.
# PGMREC_EXPORTS_DIR=/opt/pgmrec/data/exports

# Export job FFmpeg log directory.
# PGMREC_EXPORT_LOGS_DIR=/opt/pgmrec/logs/exports

# HLS preview output directory.
# PGMREC_PREVIEW_DIR=/opt/pgmrec/data/preview

# ─── FFmpeg ───────────────────────────────────────────────────────────────────

# Global FFmpeg binary path override.
# If set, this overrides per-channel ffmpeg_path in channel JSON configs.
# Linux: leave empty to use per-channel config, or point to system install:
# PGMREC_FFMPEG_PATH_OVERRIDE=/usr/bin/ffmpeg
# Windows (adjust to your FFmpeg location):
# PGMREC_FFMPEG_PATH_OVERRIDE=C:\AutoRec\ffmpeg\bin\ffmpeg.exe

# FFprobe binary used by manifest/export services.
# PGMREC_FFPROBE_PATH=ffprobe
# Windows: PGMREC_FFPROBE_PATH=C:\AutoRec\ffmpeg\bin\ffprobe.exe

# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite database URL.  Default: backend/pgmrec.db
# Linux systemd:  PGMREC_DATABASE_URL=sqlite:////opt/pgmrec/data/pgmrec.db
# Windows:        PGMREC_DATABASE_URL=sqlite:///C:/PGMRec/data/pgmrec.db
# PGMREC_DATABASE_URL=sqlite:////opt/pgmrec/data/pgmrec.db

# ─── Export limits ────────────────────────────────────────────────────────────

# Maximum number of concurrent export jobs.
# PGMREC_MAX_CONCURRENT_EXPORTS=2

# Maximum export duration in seconds (0 = unlimited).
# PGMREC_MAX_EXPORT_DURATION_SECONDS=7200

# Delete exported files older than this many days (0 = disabled).
# PGMREC_EXPORT_RETENTION_DAYS=30

# ─── Watchdog / process control ───────────────────────────────────────────────

# Watchdog polling interval (seconds).
# PGMREC_WATCHDOG_INTERVAL_SECONDS=10

# Number of seconds without new segment output before a stall is declared.
# PGMREC_STALL_DETECTION_SECONDS=60

# Stop timeout before SIGKILL (seconds).
# PGMREC_STOP_TIMEOUT_SECONDS=15
